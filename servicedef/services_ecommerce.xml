<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/services.xsd">
    <description>Mpstyle Services</description>
    <vendor></vendor>
    <version>1.0</version>

    <service name="performCategoryFilterSearch" engine="groovy"
             location="component://mpstyle/src/main/groovy/ecommerce/EcommerceServices.groovy"
             auth="false" invoke="performCategoryFilterSearch">
        <description>Filtering products within a specific category given a set of features</description>
        <attribute name="productCategoryId" mode="IN" type="String" optional="false"/>
        <attribute name="filterFeatureMap" mode="IN" type="Map" optional="false"/>
        <attribute name="productStoreId" mode="IN" type="String" optional="true"/>
        <attribute name="prodCatalogId" mode="IN" type="String" optional="false"/>
        <attribute name="defaultViewSize" mode="IN" type="Integer" optional="false"/>
        <attribute name="limitView" mode="IN" type="Boolean" optional="true" default-value="false"/>
        <attribute name="filteredProductCategoryMembers" type="java.util.Collection" mode="OUT" optional="true"/> <!-- this list will only contain the filtered members -->
        <attribute name="appliedFiltersByFeatureType" type="Map" mode="OUT" optional="true"/> <!-- filter applied by featureType -->
        <attribute name="filteredProductCategoryId" type="String" mode="OUT" optional="true"/> <!-- filtered Category -->
    </service>
    
</services>